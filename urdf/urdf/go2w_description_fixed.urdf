    <plugin name="go2w_wheel_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <robotNamespace>/</robotNamespace>
      <updateRate>100</updateRate>
      <jointName>FL_foot_joint,FR_foot_joint,RL_foot_joint,RR_foot_joint</jointName>
    </plugin>

    <plugin name="go2w_skid_steer_drive" filename="libgazebo_ros_skid_steer_drive.so">
      <robotNamespace>/</robotNamespace>
      <leftFrontJoint>FL_foot_joint</leftFrontJoint>
      <rightFrontJoint>FR_foot_joint</rightFrontJoint>
      <leftRearJoint>RL_foot_joint</leftRearJoint>
      <rightRearJoint>RR_foot_joint</rightRearJoint>
      <wheelSeparation>0.284</wheelSeparation>
      <wheelDiameter>0.10</wheelDiameter>
      <torque>10.0</torque>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <broadcastTF>true</broadcastTF>
      <updateRate>100</updateRate>
    </plugin>
  </gazebo>

  <gazebo reference="header_lidar">
    <material>Gazebo/Orange</material>
    <ambient>1 0.4 0 1</ambient>
    <diffuse>1 0.4 0 1</diffuse>
    <specular>0.2 0.2 0.2 1</specular>
    <emissive>0.1 0.04 0 1</emissive>
    <sensor type="gpu_ray" name="hesai_xt16_sensor">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>false</visualize>
      <pose>0 0 0 0 0 0</pose>
      <ray>
        <scan>
          <horizontal>
            <samples>1800</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.261799</min_angle>
            <max_angle>0.261799</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>120.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_hesai_xt16" filename="libgazebo_ros_gpu_laser.so">
        <topicName>/hesai_points</topicName>
        <frameName>header_lidar</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>
