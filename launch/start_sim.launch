<launch>
  <arg name="gui" default="true"/>
  <arg name="rviz" default="true"/>
  <arg name="use_map" default="true"/>
  <arg name="map_yaml" default="$(find motion_control)/maps/follow_sense.yaml"/>
  <arg name="unable_gazebo_physics" default="false"/>
  <arg name="x" default="0.0"/>
  <arg name="y" default="0.0"/>
  <arg name="z" default="0.35"/>


  <param name="robot_description" textfile="$(find motion_control)/urdf/urdf/go2w_description_fixed.urdf"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find motion_control)/worlds/follow_sense.generated.world"/>
    <arg name="paused" value="$(arg unable_gazebo_physics)"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="$(arg gui)"/>
  </include>

  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>
  <node if="$(arg use_map)" pkg="map_server" type="map_server" name="map_server" args="$(arg map_yaml)"/>
  <node if="$(arg use_map)" pkg="tf2_ros" type="static_transform_publisher" name="map_to_odom_tf" args="0 0 0 0 0 0 map odom"/>

  <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf" 
        args="-urdf -param robot_description -model go2w -x $(arg x) -y $(arg y) -z $(arg z)" 
        output="screen" />

  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz" args="-d $(find motion_control)/rviz/motion_control.rviz"/>
</launch>
